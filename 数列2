    <div class="quiz-result" id="qr2"></div>
  </div>

  <div class="quiz-box">
    <div class="quiz-q">【問題2-(1)】1,4,2,1,4,2... を70こならべます。<br><b>1</b> は全部で何こありますか？</div>
    <input class="quiz-input" id="qi3" type="number" placeholder="?">
    <button class="quiz-btn" onclick="checkQ(3)">答え合わせ</button>
    <div class="quiz-result" id="qr3"></div>
  </div>

  <div class="quiz-box">
    <div class="quiz-q">【問題2-(2)】ならべた数を全部たすといくつになりますか？</div>
    <input class="quiz-input" id="qi4" type="number" placeholder="?">
    <button class="quiz-btn" onclick="checkQ(4)">答え合わせ</button>
    <div class="quiz-result" id="qr4"></div>
  </div>

  <div class="exp" id="exp2"></div>
</div>

<!-- ====== TAB 3: 探検 ====== -->
<div class="card tc" id="tc3">
  <div class="card-title"><span class="badge">探検</span>自分でくり返しパターンを作ろう</div>
  <div class="btns">
    <button class="btn on" onclick="selExp(0)">1,2,3</button>
    <button class="btn" onclick="selExp(1)">5,0,5,0</button>
    <button class="btn" onclick="selExp(2)">1,2,3,4,5</button>
    <button class="btn" onclick="selExp(3)">3,1,4,1,5,9</button>
  </div>
  <div class="ctrl">
    <label>何こならべる？</label>
    <input type="range" min="10" max="100" value="40" id="sl3" oninput="draw3()">
    <span class="val" id="sl3v">40</span>こ
  </div>
  <div class="ctrl">
    <label>何番目を調べる？</label>
    <input type="range" min="1" max="100" value="1" id="sl3b" oninput="draw3()">
    <span class="val" id="sl3bv">1</span>番目
  </div>
  <div class="grid" id="grid3"></div>
  <div class="info-row" id="info3"></div>
  <div class="calc" id="calc3"></div>
  <div class="exp" id="exp3"></div>
</div>

<script>
// ====== TABS ======
function switchTab(n){
  document.querySelectorAll('.tab').forEach((t,i)=>t.classList.toggle('on',i===n));
  document.querySelectorAll('.tc').forEach((c,i)=>c.classList.toggle('on',i===n));
  if(n===0)draw0();if(n===1)draw1();if(n===3)draw3();
}

// ====== HELPERS ======
const colors=['grp0','grp1','grp2'];

function buildGrid(containerId, pattern, total, highlightIdx){
  const grid=document.getElementById(containerId);
  grid.innerHTML='';
  const period=pattern.length;
  const fullSets=Math.floor(total/period);
  const remainder=total%period;
  const totalSets=fullSets+(remainder>0?1:0);

  for(let s=0;s<totalSets;s++){
    const setDiv=document.createElement('div');
    const isRemainder=(s===fullSets && remainder>0);
    const count=isRemainder?remainder:period;
    setDiv.className='set-group '+(isRemainder?'remainder':(s%2===0?'even':'odd'));

    // Set label
    const lbl=document.createElement('span');
    lbl.className='set-label';
    if(isRemainder){
      lbl.textContent='あまり'+remainder+'こ';
    }else{
      lbl.textContent=(s+1)+'セット目';
    }
    setDiv.appendChild(lbl);

    for(let j=0;j<count;j++){
      const i=s*period+j;
      const val=pattern[i%period];
      const grpClass=colors[i%period];
      const cell=document.createElement('div');
      cell.className='cell '+grpClass;
      if(i===highlightIdx) cell.classList.add('hi');
      // Show index for first, last of set, highlighted, and every 5th
      if(j===0 || j===count-1 || i===highlightIdx || (i+1)%10===0){
        const idx=document.createElement('span');
        idx.className='idx';
        idx.textContent=(i+1);
        cell.appendChild(idx);
      }
      const txt=document.createTextNode(val);
      cell.appendChild(txt);
      setDiv.appendChild(cell);
    }
    grid.appendChild(setDiv);
  }
}

function getAtPosition(pattern, n){
  // n is 1-based position
  const period=pattern.length;
  const rem=n%period;
  return pattern[rem===0?period-1:rem-1];
}

function countInTotal(pattern, total, target){
  const period=pattern.length;
  const fullCycles=Math.floor(total/period);
  const remainder=total%period;
  let countInCycle=0;
  for(let i=0;i<period;i++) if(pattern[i]===target) countInCycle++;
  let countInRemainder=0;
  for(let i=0;i<remainder;i++) if(pattern[i]===target) countInRemainder++;
  return fullCycles*countInCycle+countInRemainder;
}

function sumAll(pattern, total){
  const period=pattern.length;
  const fullCycles=Math.floor(total/period);
  const remainder=total%period;
  let cycleSum=0;
  for(let i=0;i<period;i++) cycleSum+=pattern[i];
  let remSum=0;
  for(let i=0;i<remainder;i++) remSum+=pattern[i];
  return fullCycles*cycleSum+remSum;
}

// ====== TAB 0: 1,4,7 x 55 ======
function draw0(){
  const n=parseInt(document.getElementById('sl0').value);
  document.getElementById('sl0v').textContent=n;
  const pat=[1,4,7], total=55, period=3;

  buildGrid('grid0',pat,total,n-1);

  const quo=Math.floor(n/period);
  const rem=n%period;
  const ans=getAtPosition(pat,n);

  document.getElementById('q0_quo').textContent=quo;
  document.getElementById('q0_rem').textContent=rem;
  document.getElementById('q0_ans').textContent=ans;

  const remText=rem===0?period:rem;
  document.getElementById('calc0').innerHTML=
    `<b>${n}</b> ÷ <b>${period}</b> = <b>${quo}</b> あまり <b>${rem}</b><br>`+
    (rem===0
      ?`あまり0 → セットの<b>最後（${period}番目）</b>の数 → パターンの${period}番目 = <span class="ans">${ans}</span>`
      :`あまり${rem} → セットの<b>${rem}番目</b>の数 → パターンの${rem}番目 = <span class="ans">${ans}</span>`);

  // Count each number
  const c1=countInTotal(pat,total,1);
  const c4=countInTotal(pat,total,4);
  const c7=countInTotal(pat,total,7);

  document.getElementById('exp0').innerHTML=`
    <div class="step"><span class="sn">🔄</span> パターン <b>1, 4, 7</b> が <b>${period}こ</b>で1セット。これを55こならべます</div>
    <div class="step"><span class="sn">📐</span> 55 ÷ 3 = <b>18セット</b> あまり <b>1</b> → 18回くり返し + 最初の1こ（=1）</div>
    <div class="step"><span class="sn">🔢</span> 各数字の個数: 1は<b>${c1}こ</b>、4は<b>${c4}こ</b>、7は<b>${c7}こ</b>（合計${c1+c4+c7}こ）</div>
    <div class="step"><span class="sn">💡</span> <b>N番目の数を求めるコツ:</b> N ÷ 周期 のあまりで、パターンの何番目かがわかる！</div>`;
}

// ====== TAB 1: 1,4,2 x 70 ======
function draw1(){
  const n=parseInt(document.getElementById('sl1').value);
  document.getElementById('sl1v').textContent=n;
  const pat=[1,4,2], total=70, period=3;

  buildGrid('grid1',pat,total,n-1);

  const quo=Math.floor(n/period);
  const rem=n%period;
  const ans=getAtPosition(pat,n);

  document.getElementById('q1_quo').textContent=quo;
  document.getElementById('q1_rem').textContent=rem;
  document.getElementById('q1_ans').textContent=ans;

  const remText=rem===0?period:rem;
  document.getElementById('calc1').innerHTML=
    `<b>${n}</b> ÷ <b>${period}</b> = <b>${quo}</b> あまり <b>${rem}</b><br>`+
    (rem===0
      ?`あまり0 → セットの<b>最後（${period}番目）</b>の数 → パターンの${period}番目 = <span class="ans">${ans}</span>`
      :`あまり${rem} → セットの<b>${rem}番目</b>の数 → パターンの${rem}番目 = <span class="ans">${ans}</span>`);

  const c1=countInTotal(pat,total,1);
  const c4=countInTotal(pat,total,4);
  const c2=countInTotal(pat,total,2);
  const s=sumAll(pat,total);

  document.getElementById('exp1').innerHTML=`
    <div class="step"><span class="sn">🔄</span> パターン <b>1, 4, 2</b> が <b>${period}こ</b>で1セット。これを70こならべます</div>
    <div class="step"><span class="sn">📐</span> 70 ÷ 3 = <b>23セット</b> あまり <b>1</b> → 23回くり返し + 最初の1こ（=1）</div>
    <div class="step"><span class="sn">🔢</span> 各数字の個数: 1は<b>${c1}こ</b>、4は<b>${c4}こ</b>、2は<b>${c2}こ</b></div>
    <div class="step"><span class="sn">➕</span> 1セットの合計: 1+4+2=<b>7</b> → 全部の合計: 23×7 + 1 = <b>${s}</b></div>
    <div class="step"><span class="sn">💡</span> <b>合計を求めるコツ:</b> 1セットの合計 × セット数 + あまり分を足す！</div>`;
}

// ====== TAB 2: クイズ ======
const quizAnswers=[
  {ans:4, explain:'20÷3=6あまり2 → パターンの2番目 = <b>4</b>'},
  {ans:7, explain:'30÷3=10あまり0 → パターンの3番目（最後）= <b>7</b>'},
  {ans:18, explain:'55÷3=18あまり1 → 4は毎セット1回、あまりの1こ目は「1」なので4は含まない → <b>18こ</b>'},
  {ans:24, explain:'70÷3=23あまり1 → 1は毎セット1回＝23こ、あまりの1こ目は「1」なので+1 → <b>24こ</b>'},
  {ans:162, explain:'1セットの合計=1+4+2=7、23セット×7=161、あまり1こ（=1）を足して → <b>162</b>'}
];

function checkQ(i){
  const inp=document.getElementById('qi'+i);
  const res=document.getElementById('qr'+i);
  const val=parseInt(inp.value);
  if(isNaN(val)){res.textContent='数を入れてね！';res.className='quiz-result ng';return;}
  const q=quizAnswers[i];
  if(val===q.ans){
    res.innerHTML='⭕ 正解！ '+q.explain;
    res.className='quiz-result ok';
  }else{
    res.innerHTML='❌ 答えは '+q.ans+'。 '+q.explain;
    res.className='quiz-result ng';
  }
}

// ====== TAB 3: 探検 ======
const expPatterns=[[1,2,3],[5,0,5,0],[1,2,3,4,5],[3,1,4,1,5,9]];
let expIdx=0;
function selExp(n){
  expIdx=n;
  document.querySelectorAll('#tc3 .btn').forEach((b,i)=>b.classList.toggle('on',i===n));
  document.getElementById('sl3b').max=parseInt(document.getElementById('sl3').value);
  draw3();
}

function draw3(){
  const pat=expPatterns[expIdx];
  const total=parseInt(document.getElementById('sl3').value);
  document.getElementById('sl3v').textContent=total;
  const sl3b=document.getElementById('sl3b');
  if(parseInt(sl3b.max)!==total) sl3b.max=total;
  if(parseInt(sl3b.value)>total) sl3b.value=total;
  const n=parseInt(sl3b.value);
  document.getElementById('sl3bv').textContent=n;

  const period=pat.length;
  buildGrid('grid3',pat,total,n-1);

  const ans=getAtPosition(pat,n);
  const quo=Math.floor(n/period);
  const rem=n%period;
  const s=sumAll(pat,total);

  // Unique values and their counts
  const unique=[...new Set(pat)];
  let countHtml='';
  unique.forEach(v=>{
    const c=countInTotal(pat,total,v);
    countHtml+=`<div class="info-card" style="background:#f5f5f5"><div class="lbl">${v}の個数</div><div class="val">${c}</div></div>`;
  });

  document.getElementById('info3').innerHTML=`
    <div class="info-card" style="background:#e3f2fd"><div class="lbl">パターン</div><div class="val" style="font-size:1em;color:#1565c0">${pat.join(', ')}</div></div>
    <div class="info-card" style="background:#fce4ec"><div class="lbl">周期</div><div class="val" style="color:#c62828">${period}こ</div></div>
    <div class="info-card" style="background:#ede7f6"><div class="lbl">${n}番目の数</div><div class="val" style="color:#6c5ce7">${ans}</div></div>
    <div class="info-card" style="background:#fff3e0"><div class="lbl">全部の合計</div><div class="val" style="color:#e17055">${s}</div></div>
    ${countHtml}`;

  document.getElementById('calc3').innerHTML=
    `<b>${n}</b> ÷ <b>${period}</b> = <b>${quo}</b> あまり <b>${rem}</b> → `+
    (rem===0
      ?`パターンの<b>${period}番目</b> = <span class="ans">${ans}</span>`
      :`パターンの<b>${rem}番目</b> = <span class="ans">${ans}</span>`);

  const cycleSum=pat.reduce((a,b)=>a+b,0);
  const fullCycles=Math.floor(total/period);
  const remCount=total%period;
  let remSum=0;for(let i=0;i<remCount;i++)remSum+=pat[i];

  document.getElementById('exp3').innerHTML=`
    <div class="step"><span class="sn">🔄</span> パターン <b>[${pat.join(', ')}]</b> を <b>${total}こ</b> ならべています</div>
    <div class="step"><span class="sn">📐</span> ${total} ÷ ${period} = <b>${fullCycles}セット</b> あまり <b>${remCount}</b></div>
    <div class="step"><span class="sn">➕</span> 1セットの合計=${cycleSum} → 全部の合計: ${fullCycles}×${cycleSum}${remCount>0?'+'+remSum:''}=<b>${s}</b></div>
    <div class="step"><span class="sn">💡</span> スライダーを動かして、いろいろなパターンを試してみよう！</div>`;
}

// ====== INIT ======
draw0();
</script>
