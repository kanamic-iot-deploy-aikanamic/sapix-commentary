<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>くり返しの数列 インタラクティブ解説</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Hiragino Sans','Meiryo',sans-serif;background:linear-gradient(135deg,#e17055,#fdcb6e);min-height:100vh;padding:16px;color:#333}
h1{text-align:center;color:#fff;font-size:1.7em;text-shadow:0 2px 8px rgba(0,0,0,.25);margin-bottom:4px}
.sub{text-align:center;color:rgba(255,255,255,.9);margin-bottom:16px;font-size:.95em}
.tabs{display:flex;gap:0;max-width:960px;margin:0 auto}
.tab{flex:1;padding:13px 6px;text-align:center;font-weight:700;font-size:.88em;cursor:pointer;border-radius:14px 14px 0 0;transition:.3s;background:rgba(255,255,255,.45);color:#555}
.tab.on{background:#fff;color:#e17055}
.card{background:#fff;border-radius:0 0 20px 20px;box-shadow:0 10px 40px rgba(0,0,0,.15);padding:20px;max-width:960px;margin:0 auto 20px}
.card-title{font-size:1.1em;font-weight:700;color:#e17055;margin-bottom:12px;display:flex;align-items:center;gap:8px}
.badge{background:linear-gradient(135deg,#e17055,#fdcb6e);color:#fff;padding:3px 12px;border-radius:16px;font-size:.7em}
.tc{display:none}.tc.on{display:block}

/* Sequence grid */
.grid{display:flex;flex-wrap:wrap;gap:2px;justify-content:center;margin:12px 0;align-items:flex-end}
.set-group{display:inline-flex;gap:2px;border:2px solid #e0d6cc;border-radius:10px;padding:18px 3px 4px;position:relative;margin:2px 2px 14px;background:rgba(255,252,245,0.5)}
.set-group.even{border-color:#d0e8f7;background:rgba(224,242,253,0.2)}
.set-group.odd{border-color:#f7d0d0;background:rgba(252,228,236,0.15)}
.set-group .set-label{position:absolute;top:-10px;left:50%;transform:translateX(-50%);background:#fff;padding:0 5px;font-size:.6em;font-weight:700;color:#999;white-space:nowrap;border-radius:6px}
.set-group.even .set-label{color:#1565c0}
.set-group.odd .set-label{color:#c62828}
.set-group.remainder{border-color:#ff9800;border-style:dashed;background:rgba(255,152,0,0.08)}
.set-group.remainder .set-label{color:#e65100;font-weight:800}
.cell{width:38px;height:38px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1.1em;font-weight:800;border:2px solid transparent;position:relative;transition:.2s}
.cell .idx{position:absolute;bottom:-15px;font-size:.55em;font-weight:600;color:#999}
.cell.hi{transform:scale(1.18);box-shadow:0 3px 12px rgba(0,0,0,.25);border-color:#333;z-index:2}
.cell.target{border-color:#e74c3c;border-width:3px}
.grp0{background:#e3f2fd;color:#1565c0}
.grp1{background:#fce4ec;color:#c62828}
.grp2{background:#e8f5e9;color:#2e7d32}

/* Controls */
.ctrl{text-align:center;margin:14px 0}
.ctrl label{font-weight:700;color:#e17055;font-size:1em}
.ctrl input[type=range]{width:60%;accent-color:#e17055;vertical-align:middle}
.ctrl .val{font-weight:800;font-size:1.4em;color:#e17055;margin-left:6px}
.btns{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;margin:12px 0}
.btn{padding:9px 16px;border-radius:22px;border:2px solid #ddd;background:#fff;font-weight:700;font-size:.88em;cursor:pointer;transition:.2s}
.btn:hover{transform:translateY(-1px);box-shadow:0 4px 12px rgba(0,0,0,.1)}
.btn.on{border-color:#e17055;background:#fef0e7;color:#e17055}

/* Info cards */
.info-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:8px;margin:12px 0}
.info-card{border-radius:12px;padding:10px;text-align:center;border:2px solid #eee}
.info-card .lbl{font-size:.72em;color:#888;margin-bottom:2px}
.info-card .val{font-size:1.4em;font-weight:800}

/* Explanation */
.exp{margin-top:12px;background:#fef0e7;border-left:5px solid #e17055;border-radius:0 12px 12px 0;padding:12px 16px;font-size:.93em;line-height:1.8;color:#5d4037}
.exp b{color:#e17055}
.step{margin-bottom:5px}
.sn{display:inline-block;background:#e17055;color:#fff;width:22px;height:22px;border-radius:50%;text-align:center;line-height:22px;font-size:.75em;font-weight:700;margin-right:5px}

/* Quiz */
.quiz-box{background:#fff8f0;border:2px solid #fdcb6e;border-radius:14px;padding:16px;margin:10px 0;text-align:center}
.quiz-q{font-weight:700;font-size:1.05em;margin-bottom:10px;color:#5d4037}
.quiz-input{width:80px;height:44px;border:3px solid #e17055;border-radius:10px;font-size:1.3em;font-weight:700;text-align:center;color:#e17055;outline:none;background:#fff}
.quiz-input:focus{border-color:#0984e3;background:#e3f2fd;color:#0984e3}
.quiz-btn{padding:8px 22px;border-radius:20px;border:none;background:linear-gradient(135deg,#e17055,#ff7675);color:#fff;font-weight:700;font-size:.95em;cursor:pointer;margin-left:8px}
.quiz-result{margin-top:8px;font-weight:700;font-size:1em;min-height:24px}
.quiz-result.ok{color:#27ae60}.quiz-result.ng{color:#e74c3c}

/* Calculation display */
.calc{background:#f8f9fa;border-radius:12px;padding:14px;margin:10px 0;text-align:center;font-size:1.05em;line-height:2}
.calc b{color:#e17055;font-size:1.15em}
.calc .ans{color:#c62828;font-weight:800;font-size:1.3em}
</style>
</head>
<body>

<h1>くり返しの数列</h1>
<p class="sub">くり返しパターンと「わり算のあまり」で解こう！</p>

<div class="tabs">
  <div class="tab on" onclick="switchTab(0)">🔄 p6: 1,4,7の列</div>
  <div class="tab" onclick="switchTab(1)">🔄 p8: 1,4,2の列</div>
  <div class="tab" onclick="switchTab(2)">🧩 クイズ</div>
