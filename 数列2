</div>

<!-- ====== TAB 0: 問題1 (1,4,7) ====== -->
<div class="card tc on" id="tc0">
  <div class="card-title"><span class="badge">問題1</span>1, 4, 7 を55こならべる</div>
  <div class="ctrl">
    <label>何番目？</label>
    <input type="range" min="1" max="55" value="20" id="sl0" oninput="draw0()">
    <span class="val" id="sl0v">20</span>番目
  </div>
  <div class="grid" id="grid0"></div>
  <div class="info-row">
    <div class="info-card" style="background:#e3f2fd"><div class="lbl">くり返しパターン</div><div class="val" style="color:#1565c0">1, 4, 7</div></div>
    <div class="info-card" style="background:#fce4ec"><div class="lbl">周期（1セット）</div><div class="val" style="color:#c62828">3こ</div></div>
    <div class="info-card" style="background:#fff3e0"><div class="lbl">N ÷ 3 の商</div><div class="val" id="q0_quo" style="color:#e17055">6</div></div>
    <div class="info-card" style="background:#e8f5e9"><div class="lbl">あまり</div><div class="val" id="q0_rem" style="color:#2e7d32">2</div></div>
    <div class="info-card" style="background:#ede7f6"><div class="lbl">答え（N番目の数）</div><div class="val" id="q0_ans" style="color:#6c5ce7">4</div></div>
  </div>
  <div class="calc" id="calc0"></div>
  <div class="exp" id="exp0"></div>
</div>

<!-- ====== TAB 1: 問題2 (1,4,2) ====== -->
<div class="card tc" id="tc1">
  <div class="card-title"><span class="badge">問題2</span>1, 4, 2 を70こならべる</div>
  <div class="ctrl">
    <label>何番目？</label>
    <input type="range" min="1" max="70" value="1" id="sl1" oninput="draw1()">
    <span class="val" id="sl1v">1</span>番目
  </div>
  <div class="grid" id="grid1"></div>
  <div class="info-row">
    <div class="info-card" style="background:#e3f2fd"><div class="lbl">くり返しパターン</div><div class="val" style="color:#1565c0">1, 4, 2</div></div>
    <div class="info-card" style="background:#fce4ec"><div class="lbl">周期（1セット）</div><div class="val" style="color:#c62828">3こ</div></div>
    <div class="info-card" style="background:#fff3e0"><div class="lbl">N ÷ 3 の商</div><div class="val" id="q1_quo" style="color:#e17055">0</div></div>
    <div class="info-card" style="background:#e8f5e9"><div class="lbl">あまり</div><div class="val" id="q1_rem" style="color:#2e7d32">1</div></div>
    <div class="info-card" style="background:#ede7f6"><div class="lbl">答え（N番目の数）</div><div class="val" id="q1_ans" style="color:#6c5ce7">1</div></div>
  </div>
  <div class="calc" id="calc1"></div>
  <div class="exp" id="exp1"></div>
</div>

<!-- ====== TAB 2: クイズ ====== -->
<div class="card tc" id="tc2">
  <div class="card-title"><span class="badge">クイズ</span>プリントの問題に答えよう！</div>

  <div class="quiz-box">
    <div class="quiz-q">【問題1-(1)】1,4,7,1,4,7... を55こならべます。<br>左から数えて <b>20番目</b> の数字は何ですか？</div>
    <input class="quiz-input" id="qi0" type="number" placeholder="?">
    <button class="quiz-btn" onclick="checkQ(0)">答え合わせ</button>
    <div class="quiz-result" id="qr0"></div>
  </div>

  <div class="quiz-box">
    <div class="quiz-q">【問題1-(2)】左から数えて <b>30番目</b> の数字は何ですか？</div>
    <input class="quiz-input" id="qi1" type="number" placeholder="?">
    <button class="quiz-btn" onclick="checkQ(1)">答え合わせ</button>
    <div class="quiz-result" id="qr1"></div>
  </div>

  <div class="quiz-box">
    <div class="quiz-q">【問題1-(3)】55こ全部の中で、<b>4</b> は何こありますか？</div>
    <input class="quiz-input" id="qi2" type="number" placeholder="?">
